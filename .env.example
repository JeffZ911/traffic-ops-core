# ============================================
# Traffic Ops .env template
# Copy to .env and fill values. .env is gitignored.
# Variable names must match GitHub Secrets exactly (CREDENTIALS-SETUP.md §2).
# ============================================

# === Supabase ===
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_DB_URL=

# === Gemini API ===
GEMINI_API_KEY=

# === Email alerts ===
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
ALERT_RECIPIENT_EMAIL=

# === Cloudflare ===
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# === GitHub & Git ===
GITHUB_TOKEN=
GIT_USER_NAME=
GIT_USER_EMAIL=

# === NTE site-specific (site_slug = ntecodex) ===
NTECODEX_GA4_PROPERTY_ID=
NTECODEX_FB_AD_ACCOUNT_ID=
NTECODEX_FB_PIXEL_ID=
NTECODEX_FB_ACCESS_TOKEN=
NTECODEX_ADSENSE_PUBLISHER_ID=
NTECODEX_GOOGLE_SERVICE_ACCOUNT_JSON=
